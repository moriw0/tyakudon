<% add_breadcrumb t('shared.breadcrumb_home'), root_path %>
<hr>

<%= render 'shared/nav' %>
<hr>

<h1><%= t('.heading') %></h1>

<p><%= t('.description') %></p>

<%= form_with url: password_resets_path, scope: :password_reset do |f| %>
  <p>
    <%= f.label :email, t('.email_label') %>
    <%= f.email_field :email %>
  </p>
  <p><%= f.submit t('.submit'), class: 'btn btn-block', data: { turbo_submits_with: t('.submit_disable_with') } %></p>
<% end %>

<hr>
<p><%= link_to t('.back_to_login'), login_path %></p>
