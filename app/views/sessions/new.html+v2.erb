<p><%= link_to t('.breadcrumb_home'), root_path %></p>
<hr>

<%= render 'shared/nav' %>
<hr>

<h1><%= t('.heading') %></h1>

<%= form_with url: login_path, scope: :session do |f| %>
  <p>
    <%= f.label :email, t('.email_label') %>
    <%= f.email_field :email %>
  </p>
  <p>
    <%= f.label :password, t('.password_label') %>
    <%= f.password_field :password %>
  </p>
  <p>
    <%= f.check_box :remember_me %>
    <%= f.label :remember_me, t('.remember_me') %>
  </p>
  <p><%= f.submit t('.submit'), class: 'btn btn-block' %></p>
<% end %>

<hr>
<%= render 'shared/google_login' %>

<hr>
<p><%= link_to t('.forgot_password'), new_password_reset_path %></p>
<p><%= link_to t('.sign_up'), new_user_path %></p>
