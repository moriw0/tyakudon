<%= render 'shared/nav' %>
<hr>

<h1><%= t('.heading') %></h1>

<% if @records.any? %>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th scope="col"><%= t('.shop_name_header') %></th>
          <th scope="col"><%= t('.wait_time_header') %></th>
          <th scope="col" class="col-genre"><%= t('.status_header') %></th>
          <th scope="col"><%= t('.datetime_header') %></th>
          <th scope="col" class="col-author"><%= t('.author_header') %></th>
        </tr>
      </thead>
      <tbody>
        <% @records.each do |record| %>
          <tr>
            <td><%= link_to record.ramen_shop.name, record.ramen_shop %></td>
            <td>
              <% if record.wait_time %>
                <%= link_to format_wait_time_human(record.wait_time), record_path(record) %>
              <% else %>
                <%= link_to t('.connecting'), record_path(record) %>
              <% end %>
            </td>
            <td class="col-genre"><%= format_line_status(record.line_statuses.first) %></td>
            <td><%= format_datetime(record.started_at) %></td>
            <td class="col-author"><%= link_to record.user.name, record.user %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <%= paginate @records %>
<% else %>
  <p><%= t('.no_records') %></p>
<% end %>
