<% if records.any? %>
  <div class="table-scroll">
    <table>
      <caption class="sr-only"><%= local_assigns.fetch(:caption, t('new_records.index.heading')) %></caption>
      <thead>
        <tr>
          <th scope="col"><%= t('new_records.index.shop_name_header') %></th>
          <th scope="col"><%= t('new_records.index.wait_time_header') %></th>
          <th scope="col" class="col-genre"><%= t('new_records.index.status_header') %></th>
          <th scope="col"><%= t('new_records.index.datetime_header') %></th>
          <th scope="col" class="col-author"><%= t('new_records.index.author_header') %></th>
          <th scope="col"><%= t('shared.photo_header') %></th>
        </tr>
      </thead>
      <tbody>
        <% records.each do |record| %>
          <tr>
            <td><%= link_to record.ramen_shop.name, record.ramen_shop %></td>
            <td>
              <% if record.wait_time %>
                <%= link_to format_wait_time_human(record.wait_time), record_path(record) %>
              <% else %>
                <%= link_to t('new_records.index.connecting'), record_path(record) %>
              <% end %>
            </td>
            <td class="col-genre"><%= format_line_status(record.line_statuses.first) %></td>
            <td><%= format_datetime(record.started_at) %></td>
            <td class="col-author"><%= link_to record.user.name, record.user %></td>
            <%= render 'records/photo_thumb', record: record %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p><%= t('new_records.index.no_records') %></p>
<% end %>
